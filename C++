// WiFi
const char *nome_da_rede = "zutron";
const char *senha = "12345678";

// Pinos da ponte H
const int motorDireitaFrente = 3;
const int motorDireitaTras = 0;
const int motorEsquerdaFrente = 2;
const int motorEsquerdaTras = 1;

ESP8266WebServer servidor(80);

// Funções de controle
void frente() {
  digitalWrite(motorDireitaFrente, HIGH);
  digitalWrite(motorDireitaTras, LOW);
  digitalWrite(motorEsquerdaFrente, HIGH);
  digitalWrite(motorEsquerdaTras, LOW);
}

void tras() {
  digitalWrite(motorDireitaFrente, LOW);
  digitalWrite(motorDireitaTras, HIGH);
  digitalWrite(motorEsquerdaFrente, LOW);
  digitalWrite(motorEsquerdaTras, HIGH);
}

void parar() {
  digitalWrite(motorDireitaFrente, LOW);
  digitalWrite(motorDireitaTras, LOW);
  digitalWrite(motorEsquerdaFrente, LOW);
  digitalWrite(motorEsquerdaTras, LOW);
}

void virarDireita() {
  digitalWrite(motorDireitaFrente, LOW);
  digitalWrite(motorDireitaTras, HIGH);
  digitalWrite(motorEsquerdaFrente, HIGH);
  digitalWrite(motorEsquerdaTras, LOW);
}

void virarEsquerda() {
  digitalWrite(motorDireitaFrente, HIGH);
  digitalWrite(motorDireitaTras, LOW);
  digitalWrite(motorEsquerdaFrente, LOW);
  digitalWrite(motorEsquerdaTras, HIGH);
}

void setup() {
  pinMode(motorDireitaFrente, OUTPUT);
  pinMode(motorDireitaTras, OUTPUT);
  pinMode(motorEsquerdaFrente, OUTPUT);
  pinMode(motorEsquerdaTras, OUTPUT);

  parar();

  WiFi.softAP(nome_da_rede, senha);

  servidor.on("/", []() {
    servidor.send(200, "text/html", pagina);
  });

  servidor.on("/pressionado", HTTP_POST, []() {
    String estado = servidor.arg("plain");
    char comando = estado.charAt(0);

    switch (comando) {
      case '1': frente(); break;
      case '2': virarEsquerda(); break;
      case '3': virarDireita(); break;
      case '4': tras(); break;
      case '0': parar(); break;
      default: parar(); break;
    }

    servidor.send(200, "text/plain", "OK");
  });

  servidor.begin();
}

void loop() {
  servidor.handleClient();
}
